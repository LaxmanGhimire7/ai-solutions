flowchart LR
    User[User Browser]:::external
    Admin[Admin Browser]:::external

    subgraph Frontend["Frontend - React / Vite"]
        direction TB
        Public[Public Website]:::box
        Chat[Chatbot and Live Chat]:::box
        Dashboard[Admin Dashboard]:::box
        Inquiry[Inquiry Handling]:::box
        Content[Content Manager]:::box
    end

    subgraph Backend["Backend - Node.js / Express"]
        direction TB
        Socket[Socket.IO Chat]:::box
        Auth[JWT Authentication]:::box
        Uploads[Image Uploads and Serving]:::box
        API[REST API Routes]:::box
        CSV[CSV Export]:::box
        Email[Email Notification]:::box
    end

    subgraph Data["Data Layer"]
        direction TB
        Images[(ImageAsset Collection)]:::database
        Mongo[(MongoDB)]:::database
    end

    User --> Public
