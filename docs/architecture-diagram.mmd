    API --> Auth
    API --> Uploads
    API --> CSV
    API --> Email
    Socket --> Mongo
    Auth --> Mongo
    Uploads --> Images
    Uploads --> Mongo
    CSV --> Mongo
    Email --> Mongo
    API --> Mongo
    Images --> Mongo

